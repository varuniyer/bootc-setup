
{
	email acme@varuniyer.net
	order webdav before file_server

	log access {
		output file /var/log/caddy/access.log {
			roll_size 50MiB
			roll_keep 3
		}
		format json
	}

	servers {
		listener_wrappers {
			layer4 {
				@postgres {
					tls {
						sni db.varuniyer.net
						alpn postgresql
					}
					remote_ip POSTGRES_IP_WHITELIST
				}
				route @postgres {
					tls {
						connection_policy {
							alpn postgresql
						}
					}
					proxy tcp/127.0.0.1:5432
				}
			}
			tls
		}
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

varuniyer.net {
	import security_headers

	root * /usr/share/caddy

	@assets path *.webp *.css *.js
	header @assets Cache-Control "public, max-age=31536000, immutable"
	header Content-Security-Policy "default-src 'none'; style-src 'self'; script-src 'self'; img-src 'self'; font-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none';"

	file_server {
		precompressed br gzip
	}
}

varuniyer.info, varuniyer.me, www.varuniyer.net, www.varuniyer.info, www.varuniyer.me {
	redir https://varuniyer.net permanent
}

dav.varuniyer.net {
	import security_headers
	basic_auth argon2id {
		davuser CADDY_HASHED_PASSWORD
	}
	webdav {
		root /var/lib/webdav/data
	}
}

db.varuniyer.net {
	# Site exists only so Caddy provisions a cert for this SNI.
	# Real traffic is intercepted by the layer4 route in global options.
	respond "use postgresql protocol" 421
}

mta-sts.varuniyer.net {
	import security_headers
	@mta-sts path /.well-known/mta-sts.txt
	respond @mta-sts `version: STSv1
mode: enforce
mx: mx1.forwardemail.net
mx: mx2.forwardemail.net
max_age: 2419200` 200
	header @mta-sts Content-Type "text/plain; charset=utf-8"
}
