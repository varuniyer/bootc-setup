{
	email ${ACME_EMAIL}
	order webdav before file_server
	admin off

	servers {
		listener_wrappers {
			layer4 {
				@postgres {
					tls {
						sni db.${DOMAIN}
						alpn postgresql
					}
					remote_ip ${POSTGRES_IP_ALLOWLIST}
				}
				route @postgres {
					tls {
						connection_policy {
							alpn postgresql
						}
					}
					proxy tcp/127.0.0.1:5432
				}
			}
			tls
		}
	}
}

(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}

${DOMAIN} {
	import security_headers

	root * /usr/share/caddy

	@assets path *.webp *.css *.js
	header @assets Cache-Control "public, max-age=31536000, immutable"
	header Content-Security-Policy "default-src 'none'; style-src 'self'; script-src 'self'; img-src 'self'; font-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none';"

	file_server {
		precompressed br gzip
	}
}

${REDIR_LIST} {
	redir https://${DOMAIN} permanent
}

dav.${DOMAIN} {
	import security_headers
	basic_auth argon2id {
		${WEBDAV_USERNAME} ${WEBDAV_PASSWORD_HASH}
	}
	webdav {
		root /var/lib/webdav/data
	}
}

db.${DOMAIN} {
	# Site exists only so Caddy provisions a cert for this SNI.
	# Real traffic is intercepted by the layer4 route in global options.
	respond "use postgresql protocol" 421
}

mta-sts.${DOMAIN} {
	import security_headers
	@mta-sts path /.well-known/mta-sts.txt
	respond @mta-sts `${MTA_STS_TXT}` 200
	header @mta-sts Content-Type "text/plain; charset=utf-8"
}
