[Unit]
Description=Root-side boot setup (Caddyfile, postgres hash)
Requires=nftables.service network-online.target
After=local-fs.target network-online.target nftables.service

[Service]
Type=oneshot
ExecStart=/opt/scripts/post-startup-root.sh
RemainAfterExit=yes
RuntimeDirectory=post-startup

ProtectSystem=strict
ProtectHome=true
ProtectProc=invisible
ProtectClock=true
ProtectKernelLogs=true
ProtectKernelTunables=true
ProtectHostname=true
PrivateDevices=true
PrivateTmp=true
PrivateIPC=true
RestrictNamespaces=true
NoNewPrivileges=true
LockPersonality=true
MemoryDenyWriteExecute=true
RestrictSUIDSGID=true
RestrictAddressFamilies=AF_UNIX AF_INET
SystemCallFilter=@system-service
SystemCallArchitectures=native
CapabilityBoundingSet=
ReadWritePaths=/etc/caddy/Caddyfile

[Install]
WantedBy=multi-user.target
