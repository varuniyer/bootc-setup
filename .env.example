# Copy to .env, fill in, and encrypt with dotenvx.
# Loaded with: dotenvx run -- ./provision.sh

# GCP zone to deploy the instance in.
ZONE=us-central1-a

# GCP instance type
MACHINE_TYPE=c4a-standard-1

# GCP disk size
DISK_SIZE=50GB

# GCP disk type
DISK_TYPE=hyperdisk-balanced

# Primary domain Caddy serves. Replaces ${DOMAIN} throughout the Caddyfile.
DOMAIN=example.com

# Email Caddy registers with the ACME CA. Replaces ${ACME_EMAIL} in the Caddyfile.
ACME_EMAIL=acme@example.com

# Comma-separated Caddy site addresses that permanently redirect to https://${DOMAIN}.
REDIR_LIST="example.org, example.net, www.example.com, www.example.org, www.example.net"

# URL provision.sh fetches the MTA-STS policy body from. Its contents are served
# verbatim at https://mta-sts.${DOMAIN}/.well-known/mta-sts.txt.
MTA_STS_URL=https://example.com/mta-sts.txt

# GitHub fine-grained PAT with Actions read/write on this repo only.
# Cloud Scheduler uses it to dispatch the daily build workflow.
GH_WORKFLOW_TOKEN=github_pat_xxxxx

# Tailscale OAuth client secret (auth_keys scope only, tag:server only).
# Used directly as a non-expiring auth key on first boot.
TS_AUTHKEY=tskey-client-xxxxx

# Plaintext secrets. provision.sh hashes these so only the hashes reach metadata.
POSTGRES_PASSWORD=changeme
WEBDAV_USERNAME=dav
WEBDAV_PASSWORD=changeme
