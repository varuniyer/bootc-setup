[Unit]
Description=Provision /var state before services start
After=local-fs.target network-online.target
Wants=network-online.target
Before=httpd.service postgresql.service caddy.service stunnel@postgres.service

[Service]
Type=oneshot
ExecStart=/usr/libexec/post-startup.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
